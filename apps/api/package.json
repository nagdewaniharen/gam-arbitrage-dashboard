{
  "name": "@gam/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "auth:gam": "tsx src/cli/auth-gam.ts",
    "gam:keys": "tsx src/cli/gam-keys.ts",
    "backfill": "tsx src/cli/backfill.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.665.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@gam/db": "workspace:*",
    "@gam/types": "workspace:*",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "google-auth-library": "^9.14.1",
    "googleapis": "^144.0.0",
    "jose": "^5.10.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
