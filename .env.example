# ============================================================================
# GAM Arbitrage Reporting Dashboard — environment template
# Copy to `.env` for local development. Never commit `.env`.
# ============================================================================

# ---- Database ----
# Production: Supabase Pro. Local dev option below (Docker Postgres).
#
# When using Supabase, set BOTH:
#   DATABASE_URL = Session Pooler URL (port 5432, *.pooler.supabase.com host)
#   DIRECT_URL   = Direct Connection URL (port 5432, db.*.supabase.co host)
# Prisma uses DATABASE_URL for runtime queries and DIRECT_URL for migrations.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Local Docker fallback (if you prefer offline dev — comment Supabase URLs above)
POSTGRES_USER=gam
POSTGRES_PASSWORD=gam_dev_password
POSTGRES_DB=gam_arbitrage
POSTGRES_PORT=5432
# DATABASE_URL=postgresql://gam:gam_dev_password@localhost:5432/gam_arbitrage?schema=public
# DIRECT_URL=postgresql://gam:gam_dev_password@localhost:5432/gam_arbitrage?schema=public

# ---- API (Fastify) ----
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# Public URL used in CORS allowlist + Swagger server entry
PUBLIC_API_URL=http://localhost:4000
# Web origin allowed via CORS
WEB_ORIGIN=http://localhost:3001

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- HMAC secret for /internal/cron/* (EventBridge → API) ----
INTERNAL_CRON_SECRET=change_me_to_a_long_random_string

# ---- GAM (provided by TL via secure handoff) ----
GAM_NETWORK_CODE=YOUR_GAM_NETWORK_CODE

# ---- GAM OAuth User Flow (alternative when service account is blocked) ----
# Used by `pnpm --filter @gam/api auth:gam` CLI to get a user refresh token.
# Required redirect URI inside GCP: http://localhost:8765/callback
GAM_USER_OAUTH_CLIENT_ID=
GAM_USER_OAUTH_CLIENT_SECRET=
# Local dev only — production reads from AWS Secrets Manager.
# Drop the JSON file at ./secrets/gam-service-account.json (gitignored).
GAM_SERVICE_ACCOUNT_JSON_PATH=./secrets/gam-service-account.json
GAM_REPORT_TIMEZONE=Asia/Kolkata
GAM_BACKFILL_DAYS_ON_FIRST_RUN=90
GAM_INCREMENTAL_DAYS_PER_RUN=7

# ---- MGID (Phase 3) ----
MGID_API_KEY=change_me_when_available
MGID_API_BASE_URL=https://api.mgid.com/v1

# ---- Auth (Phase 2 — Google Workspace SSO) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NEXTAUTH_SECRET=change_me_to_a_long_random_string
NEXTAUTH_URL=http://localhost:3000
ALLOWED_GOOGLE_DOMAIN=yourdomain.com
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com

# ---- Slack (Phase 4) ----
SLACK_WEBHOOK_URL=

# ---- AWS (production deploy only) ----
AWS_REGION=ap-south-1
AWS_S3_RAW_REPORTS_BUCKET=gam-arbitrage-raw-reports
AWS_SECRETS_PREFIX=gam-arbitrage

# ---- RPV (Revenue Per Visit) — see ADR-017 ----
# Number of ad slots on a typical funnel page (verified by counting
# googletag.defineSlot + defineOutOfPageSlot calls in funnel source).
# Formula: RPV = revenue × AVG_ADS_PER_PAGE / impressions
AVG_ADS_PER_PAGE=2
NEXT_PUBLIC_AVG_ADS_PER_PAGE=2
